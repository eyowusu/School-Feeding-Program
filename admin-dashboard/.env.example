# ============================================================================
# GHANA SCHOOL FEEDING PROGRAMME - ADMIN DASHBOARD
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
# IMPORTANT: Copy this file to .env and fill in actual values before deployment
# Never commit .env file to version control
# ============================================================================

# Firebase Configuration (REQUIRED FOR PRODUCTION)
# Get these from Firebase Console -> Project Settings -> General -> Your apps
REACT_APP_FIREBASE_API_KEY=your_actual_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id

# Google Analytics (REQUIRED FOR PRODUCTION)
REACT_APP_GA_TRACKING_ID=G-XXXXXXXXXX

# Feature Flags
REACT_APP_ENABLE_REAL_TIME_SYNC=true
REACT_APP_ENABLE_PUSH_NOTIFICATIONS=true
REACT_APP_ENABLE_CONTENT_WORKFLOW=true
REACT_APP_ENABLE_ANALYTICS_DASHBOARD=true

# Application Limits
REACT_APP_MAX_UPLOAD_SIZE=10485760
REACT_APP_CONTENT_CACHE_DURATION=300000

# Security Settings
REACT_APP_ALLOWED_ORIGINS=https://gsfp.gov.gh,https://www.gsfp.gov.gh
REACT_APP_ADMIN_EMAIL_DOMAIN=gsfp.gov.gh

# Debug Settings (SET TO false IN PRODUCTION)
REACT_APP_DEBUG_MODE=false
REACT_APP_ENABLE_MOCK_DATA=false
